# ============================================================
# Stock Sentiment Predictor — Environment Configuration
# Copy this file: cp .env.example .env
# Then fill in your values below.
# ============================================================

# --- GNews API Key (Free) ---
# Sign up at https://gnews.io to get your free API key.
# Free tier: 100 requests/day, 10 articles/request
GNEWS_API_KEY=your_gnews_api_key_here

# --- Server Configuration ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
LOG_LEVEL=INFO

# --- Model Configuration ---
MODEL_DIR=models
MODEL_VERSION=xgb_v1
HISTORY_DAYS=180
CV_FOLDS=5

# --- CORS Origins (comma-separated) ---
# Add your React app's URL here
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# --- Rate Limiting (future use) ---
# MAX_REQUESTS_PER_MINUTE=30
